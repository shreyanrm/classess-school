{
  "$meta": {
    "name": "Classess Design System",
    "version": "4.1.0",
    "updated": "2026-06",
    "description": "Steel + one hit of pigment. European-minimal. Sans-only type; ultramarine signature; tight card matrices; restrained motion. Tokens are the single source of truth; never hardcode hex in app code.",
    "laws": [
      "Monochrome steel shell; colour appears only as meaning.",
      "One vivid per surface — a card belongs to a single subject.",
      "Ultramarine is the signature — brand mark + mastery ignite. Never a subject.",
      "No drop shadows; separate surfaces with hairlines, tonal steps, frost.",
      "Sharp corners (0-3px); no full-radius pills.",
      "Whitespace is compositional and generous (European-spacey).",
      "Lean on the two lightest whites (#FCFBF9, #F6F4F0) for backgrounds.",
      "When cards group, stack them tight in a matrix sharing hairlines, not floated with gaps.",
      "One sans does the whole system; weight and size carry hierarchy. Serif, mono, script are on-demand only."
    ]
  },
  "color": {
    "white": {
      "50":  { "value": "#FCFBF9", "role": "surface — cards, panels (primary background)" },
      "100": { "value": "#F6F4F0", "role": "canvas — app background (primary background)" },
      "200": { "value": "#ECE8E1", "role": "sunken — wells, tracks (use sparingly)" },
      "300": { "value": "#DCD7CE", "role": "hairline — borders, matrix rules" },
      "400": { "value": "#CFC9BE", "role": "hairline-strong" }
    },
    "black": {
      "900": { "value": "#0F0E0C", "role": "obsidian — dark canvas" },
      "800": { "value": "#171510", "role": "ink — primary text" },
      "700": { "value": "#252119", "role": "slate — dark surface" },
      "600": { "value": "#332E25", "role": "graphite-line — dark hairline" },
      "500": { "value": "#56514A", "role": "graphite — secondary text" },
      "400": { "value": "#78726A", "role": "stone — quiet text" },
      "300": { "value": "#8B857A", "role": "ash — tertiary, hints, disabled" }
    },
    "accent": {
      "_rule": "15 vivid pigments, knocked back from neon. Ultramarine is reserved as signature. The other 14 are subject identity, one hue per surface.",
      "ultramarine": { "value": "#1F35E0", "ink": "#0A1574", "tint": "#E0E4FB", "role": "SIGNATURE — brand mark + mastery ignite" },
      "cobalt":      { "value": "#1E6BFF", "ink": "#07227A", "tint": "#DEE9FF" },
      "cyan":        { "value": "#00B5D8", "ink": "#053C49", "tint": "#D2F2F8" },
      "tiffany":     { "value": "#0FC2C0", "ink": "#06403E", "tint": "#D9F6F5" },
      "emerald":     { "value": "#10A37A", "ink": "#053D2C", "tint": "#DBF3EC" },
      "acid":        { "value": "#C2F000", "ink": "#3A4A00", "tint": "#F1FBC9" },
      "amber":       { "value": "#FFB020", "ink": "#6B4500", "tint": "#FCEFD2" },
      "tangerine":   { "value": "#FF8A00", "ink": "#6B3A00", "tint": "#FCEAD2" },
      "molten":      { "value": "#FF4D1A", "ink": "#5C1A06", "tint": "#FCE4DA" },
      "hotRed":      { "value": "#EC1C2D", "ink": "#6B0710", "tint": "#FBE0E2" },
      "rose":        { "value": "#F4356E", "ink": "#6B0A2C", "tint": "#FCDDE7" },
      "magenta":     { "value": "#DD1E9A", "ink": "#6B0A49", "tint": "#FBDFF0" },
      "grape":       { "value": "#A82FE0", "ink": "#420A66", "tint": "#F0DEFB" },
      "violet":      { "value": "#7A2FF2", "ink": "#2E0A75", "tint": "#EBE0FD" },
      "indigo":      { "value": "#4B41E0", "ink": "#16107A", "tint": "#E2E0FB" }
    },
    "semantic": {
      "success": { "value": "#10936A", "ink": "#053D2C", "tint": "#DBF2E9" },
      "danger":  { "value": "#EC1C2D", "ink": "#6B0710", "tint": "#FBE0E2" },
      "warning": { "value": "#FFB020", "ink": "#6B4500", "tint": "#FCEFD2" },
      "info":    { "value": "#1F35E0", "ink": "#0A1574", "tint": "#E0E4FB", "note": "shares the signature hue" }
    },
    "themeLight": {
      "bgCanvas": "#F6F4F0", "bgSurface": "#FCFBF9", "bgRaised": "#FFFFFF", "bgSunken": "#ECE8E1",
      "border": "#DCD7CE", "borderStrong": "#CFC9BE",
      "textPrimary": "#171510", "textSecondary": "#56514A", "textTertiary": "#8B857A",
      "signature": "#1F35E0"
    },
    "themeDark": {
      "bgCanvas": "#0F0E0C", "bgSurface": "#252119", "bgRaised": "#2A251D", "bgSunken": "#1B1813",
      "border": "#332E25", "borderStrong": "#403A30",
      "textPrimary": "#F6F4F0", "textSecondary": "#B5AFA4", "textTertiary": "#7B7569",
      "signature": "#1F35E0"
    }
  },
  "subjectMap": {
    "_rule": "Assign one accent per subject; the app must ensure no two subjects shown together share a hue. Ultramarine is the signature and is NEVER a subject.",
    "mathematics": "violet",
    "physics": "cyan",
    "chemistry": "magenta",
    "biology": "emerald",
    "computerScience": "acid",
    "english": "rose",
    "socialScience": "amber",
    "secondLanguage": "tangerine",
    "_extend": "For the full 16-subject set, cycle the remaining family members (cobalt, tiffany, hotRed, molten, grape, indigo) with matched-chroma intermediates; keep the one-per-surface rule."
  },
  "typography": {
    "_principle": "One sans does the whole system. Weight (300-700) and size carry hierarchy. Serif, mono and script are on-demand only.",
    "families": {
      "sans":   { "stack": "'Google Sans Flex', 'Poppins', 'Google Sans', system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif", "role": "system — display, UI, body, everything", "alternate": "Poppins (fully open; drop-in if the Google font is ever swapped)", "axes": { "ROND": 12, "opsz": 18 }, "license": "OFL" },
      "mono":   { "stack": "'Google Sans Code', ui-monospace, 'SF Mono', monospace", "role": "proof — data, code, timestamps", "onDemand": true, "license": "OFL" },
      "script": { "stack": "'Caveat', cursive", "role": "human — margin notes, sparingly", "onDemand": true, "license": "OFL" },
      "serif":  { "stack": "'DM Serif Display', Georgia, serif", "role": "opt-in only — a rare moment that genuinely needs it; never a default", "onDemand": true, "license": "OFL" }
    },
    "weights": { "light": 300, "regular": 400, "medium": 500, "semibold": 600, "bold": 700 },
    "scale": {
      "displayLg": { "px": 64, "font": "sans", "weight": 300, "lh": 1.0,  "tracking": "-0.02em" },
      "display":   { "px": 48, "font": "sans", "weight": 300, "lh": 1.05, "tracking": "-0.02em" },
      "displaySm": { "px": 36, "font": "sans", "weight": 400, "lh": 1.05, "tracking": "-0.01em" },
      "h1": { "px": 32, "font": "sans", "weight": 600, "lh": 1.2 },
      "h2": { "px": 26, "font": "sans", "weight": 600, "lh": 1.2 },
      "h3": { "px": 21, "font": "sans", "weight": 500, "lh": 1.2 },
      "h4": { "px": 18, "font": "sans", "weight": 500, "lh": 1.2 },
      "h5": { "px": 16, "font": "sans", "weight": 500 },
      "h6": { "px": 14, "font": "sans", "weight": 500 },
      "bodyLg":  { "px": 18, "font": "sans", "weight": 400, "lh": 1.7 },
      "body":    { "px": 16, "font": "sans", "weight": 400, "lh": 1.5 },
      "bodySm":  { "px": 14, "font": "sans", "weight": 400, "lh": 1.5 },
      "caption": { "px": 13, "font": "sans", "weight": 400, "color": "textSecondary" },
      "overline":{ "px": 11, "font": "mono", "transform": "uppercase", "tracking": "0.12em" },
      "data":    { "px": 13, "font": "mono", "numeric": "tabular" },
      "code":    { "px": 14, "font": "mono" },
      "statValue": { "px": 30, "font": "sans", "weight": 500, "numeric": "tabular" }
    }
  },
  "space": { "0": 0, "1": 4, "2": 8, "3": 12, "4": 16, "5": 24, "6": 32, "7": 40, "8": 48, "9": 64, "10": 96, "11": 128, "_note": "px. Prefer 24/32/48 for section rhythm." },
  "radius": { "0": 0, "xs": 2, "sm": 3, "md": 6, "_default": "sm (3px)", "_note": "No full-radius pills." },
  "border": { "width": "0.5px", "widthStrong": "1px", "focusRing": "2px" },
  "depth": {
    "_rule": "NO drop shadows. Depth = hairline + tonal surface step + frost on overlays only.",
    "frostBg": "rgba(246,244,240,0.72)", "frostBlur": "blur(14px)", "scrim": "rgba(15,14,12,0.42)"
  },
  "patterns": {
    "matrix": {
      "_what": "Tight card grid — cards stacked close, sharing 1px hairlines instead of floating with gaps.",
      "technique": "grid with gap = border-width and background = border colour; cells get bg = surface; wrap in a container with outer border + radius:6px + overflow:hidden.",
      "hover": "a signature (ultramarine) line wipes across the top of a cell — no shadow.",
      "class": ".matrix > .cell"
    }
  },
  "motion": {
    "ease": "cubic-bezier(0.2,0,0,1)", "fast": "120ms", "base": "180ms", "slow": "260ms",
    "_principle": "Quick and certain; never bouncy. Always gated by prefers-reduced-motion.",
    "patterns": {
      "reveal": "entrance fade + 10px rise, staggered (.reveal-1..8)",
      "fillbar": "progress bars animate width from 0 to --val on load (.progress.animate)",
      "ignite": "the signature moment — an ultramarine ring expands and fades around the mastery dot (.ignite)",
      "countUp": "stat numerals count up from 0 on load (JS)",
      "matrixHover": "signature top-line wipe on cell hover"
    }
  },
  "layout": { "container": 1200, "containerNarrow": 760, "sidenavW": 248, "topbarH": 60 }
}
